{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "paths": {
      "preact": ["./node_modules/preact"],
      "preact/*": ["./node_modules/preact/*"]
    }
  },
  "include": ["taiyaki-web.d.ts", "examples/**/*.tsx", "examples/**/*.ts"]
}
